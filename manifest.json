{
  "manifest_version": 3,
  "name": "YouTube Shorts Auto Scroll",
  "description": "Automatically jumps to the next YouTube Short when the current video ends.",
  "version": "1.0.0",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/shorts/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "YouTube Shorts Auto Scroll",
    "default_popup": "popup.html"
  }
}
